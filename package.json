    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "html-to-image": "^1.11.13",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-is": "^19.2.6",

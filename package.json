{
  "name": "grapehub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server.ts",
    "build": "mkdir -p dist && npx vite build && npx esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:vite --external:pg --external:express --external:dotenv",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.0",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "firebase": "^11.0.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11"
  }
}
